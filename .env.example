DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/airbnb_lesson8?schema=public"
JWT_SECRET="change_me_to_a_long_secret"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV="development"
API_URL="http://localhost:3000"

# Groq + LangChain for Lesson 8 AI features
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

# Email reset password support
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="Airbnb API <no-reply@example.com>"

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
